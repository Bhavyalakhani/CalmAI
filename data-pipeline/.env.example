# Airflow
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=

# Postgres (internal to Docker network)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# CalmAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MONGODB_URI=
MONGODB_DATABASE=calm_ai

# GCS (for model artifact uploads)
# 1. Create a GCS service account with roles/storage.objectAdmin on your bucket
# 2. Download the JSON key and place it at data-pipeline/calm-ai-bucket-key.json
# 3. docker-compose mounts it read-only into containers at /run/secrets/gcs-key.json
#    and sets GCS_KEY_FILE=/run/secrets/gcs-key.json automatically — do NOT override here.
# 4. This variable is only needed when running scripts outside Docker (e.g. run_calm_ai_pipeline.py).
GCS_KEY_FILE=./calm-ai-bucket-key.json

# SMTP (for Airflow email_on_failure alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=

# Model Lifecycle — MLflow (experiment tracking only; model registry moved to Vertex AI)
MLFLOW_TRACKING_URI=sqlite:////opt/airflow/mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=/opt/airflow/mlruns/artifacts

# Model Lifecycle — GCS Artifact Storage
MODEL_REGISTRY_BUCKET=
MODEL_REGISTRY_PREFIX=models/bertopic

# Vertex AI Model Registry — set GCP_PROJECT_ID to enable cloud model versioning
# requires google-cloud-aiplatform and a GCP service account with Vertex AI permissions
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Model Lifecycle — Promotion Gate Thresholds
MODEL_MAX_OUTLIER_RATIO=0.20
MODEL_MIN_SILHOUETTE=0.10
MODEL_MIN_TOPIC_DIVERSITY=0.50
MODEL_MAX_BIAS_DISPARITY=0.10
MODEL_PROMOTION_MIN_SCORE_DELTA=0.01

# Model Lifecycle — Feature Flags
ENABLE_MODEL_SELECTION_GATE=true
ENABLE_MODEL_PROMOTION=true
ENABLE_MODEL_ROLLBACK=true

# Data Drift Detection — triggers retraining when distribution shift is detected
# checked when volume/time thresholds are NOT met (additional retraining signal)
ENABLE_DRIFT_DETECTION=true
DRIFT_VOCAB_THRESHOLD=0.65        # cosine similarity below this = vocabulary drift
DRIFT_EMBEDDING_THRESHOLD=0.30    # cosine distance above this = embedding drift
DRIFT_TOPIC_THRESHOLD=0.25        # JSD above this = topic distribution drift

# embedding configuration (local dev: MiniLM on CPU; cloud: Qwen 8B via endpoint)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
USE_EMBEDDING_SERVICE=false
EMBEDDING_SERVICE_URL=
