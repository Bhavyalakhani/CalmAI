# Airflow
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=

# Postgres (internal to Docker network)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# CalmAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MONGODB_URI=
MONGODB_DATABASE=calm_ai

# GCS (for model artifact uploads)
# 1. Create a GCS service account with roles/storage.objectAdmin on your bucket
# 2. Download the JSON key and place it at data-pipeline/calm-ai-bucket-key.json
# 3. docker-compose mounts it read-only into containers at /run/secrets/gcs-key.json
GCS_KEY_FILE=./calm-ai-bucket-key.json

# SMTP (for Airflow email_on_failure alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=

# Model Lifecycle — MLflow Registry
MLFLOW_TRACKING_URI=sqlite:////opt/airflow/mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=/opt/airflow/mlruns/artifacts

# Model Lifecycle — Artifact Registry (placeholder bucket)
MODEL_REGISTRY_BUCKET=
MODEL_REGISTRY_PREFIX=models/bertopic

# Model Lifecycle — Promotion Gate Thresholds
MODEL_MAX_OUTLIER_RATIO=0.20
MODEL_MIN_SILHOUETTE=0.10
MODEL_MIN_TOPIC_DIVERSITY=0.50
MODEL_MAX_BIAS_DISPARITY=0.10
MODEL_PROMOTION_MIN_SCORE_DELTA=0.01

# Model Lifecycle — Feature Flags
ENABLE_MODEL_SELECTION_GATE=true
ENABLE_MODEL_PROMOTION=true
ENABLE_MODEL_ROLLBACK=true
