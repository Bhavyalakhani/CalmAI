GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MONGODB_URI=
MONGODB_DATABASE=calm_ai_db
GOOGLE_APPLICATION_CREDENTIALS=

# backend
JWT_SECRET=calmai-dev-secret-change-in-production
SEED_PASSWORD=calmai123
FRONTEND_URL=http://localhost:3000

# embedding configuration (local dev: MiniLM on CPU; cloud: Qwen 8B via endpoint)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
USE_EMBEDDING_SERVICE=false
EMBEDDING_SERVICE_URL=

# airflow
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# postgres (airflow metadata db)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# smtp (airflow email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_SSL=False
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=

# model lifecycle — mlflow registry
MLFLOW_TRACKING_URI=sqlite:////opt/airflow/mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=/opt/airflow/mlruns/artifacts

# model lifecycle — artifact registry (placeholder bucket)
MODEL_REGISTRY_BUCKET=
MODEL_REGISTRY_PREFIX=models/bertopic

# model lifecycle — promotion gate thresholds
MODEL_MAX_OUTLIER_RATIO=0.20
MODEL_MIN_SILHOUETTE=0.10
MODEL_MIN_TOPIC_DIVERSITY=0.50
MODEL_MAX_BIAS_DISPARITY=0.10
MODEL_PROMOTION_MIN_SCORE_DELTA=0.01

# model lifecycle — feature flags
ENABLE_MODEL_SELECTION_GATE=true
ENABLE_MODEL_PROMOTION=true
ENABLE_MODEL_ROLLBACK=true

# gcp (set to enable vertex ai model registry + cloud deployment)
GCP_PROJECT_ID=
GCP_REGION=us-central1

# data drift detection
ENABLE_DRIFT_DETECTION=true
DRIFT_VOCAB_THRESHOLD=0.65
DRIFT_EMBEDDING_THRESHOLD=0.30
DRIFT_TOPIC_THRESHOLD=0.25
